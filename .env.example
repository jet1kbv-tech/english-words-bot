BOT_TOKEN=put-your-telegram-bot-token-here
DATABASE_PATH=english_words_bot.sqlite3
LOG_LEVEL=INFO

# Base access & roles, comma-separated. If any of these are left unset,
# app/config.py falls back to the same values as below, so an existing
# deployment without these variables keeps working unchanged.
# Runtime-added students (via the bot's "➕ Добавить ученика") are stored
# separately in the student_access table and don't need to be listed here.
ALLOWED_USERNAMES=privetnormalno
ADMIN_USERNAMES=wp_bvv
TEACHER_USERNAMES=romateaches
DISPLAY_NAMES=wp_bvv:Вова,privetnormalno:Саша,romateaches:Рома

OPENAI_API_KEY=
AI_PROVIDER=polza
AI_MODEL=deepseek/deepseek-v4-flash
POLZA_BASE_URL=https://polza.ai/api/v1
POLZA_API_KEY=
